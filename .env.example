# Koala platform
KOALA_API_BASE=https://koala.science/api/v1
GITHUB_REPO_URL=https://github.com/your-org/your-agent-repo
GITHUB_BRANCH=main

# Set DRY_RUN=0 only when you are ready to post comments/verdicts.
DRY_RUN=1

# Thoroughness controls. These increase local/Gemini work, not Koala karma spend.
EXHAUSTIVE_MODE=1
MAX_INTERNAL_ROLES=12
ENABLE_RETRIEVAL_FOR_ALL_AGENTS=1
MIN_VERDICT_CITATIONS=3
MAX_ACTIONS_PER_RUN=3
USE_GEMINI_IN_DRY_RUN=1
ENABLE_MODEL_TOOL_CALLS=1
MAX_TOOL_CALL_ROUNDS=2
BAYESIAN_DISCUSSION_UPDATES=1
MAX_DISCUSSION_UPDATE_WEIGHT=0.35
LOOP_INTERVAL_SECONDS=300

# Public Koala agent identities. Add these after registering agents.
KOALA_AGENT_1_NAME=EvidenceRigorAgent
KOALA_AGENT_1_API_KEY=
KOALA_AGENT_1_PUBLIC_ROLE=evidence_rigor
KOALA_AGENT_1_MIN_KARMA_RESERVE=15

KOALA_AGENT_2_NAME=LiteratureNoveltyAgent
KOALA_AGENT_2_API_KEY=
KOALA_AGENT_2_PUBLIC_ROLE=literature_novelty
KOALA_AGENT_2_MIN_KARMA_RESERVE=15

KOALA_AGENT_3_NAME=MetaCalibrationAgent
KOALA_AGENT_3_API_KEY=
KOALA_AGENT_3_PUBLIC_ROLE=meta_calibration
KOALA_AGENT_3_MIN_KARMA_RESERVE=20

# LLM and retrieval
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
SEMANTIC_SCHOLAR_API_KEY=

# Local state
DB_PATH=data/koala_agents.sqlite3
MEMORY_DB_PATH=data/memory.sqlite3
LOGS_DIR=logs
